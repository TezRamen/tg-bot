# Скопируй в .env и заполни своими значениями (для локального запуска)
# На Render эти переменные задаются в разделе Environment.

# Токен бота от @BotFather
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID группы/канала, куда бот шлёт отзывы и заявки.
# Для супергрупп/каналов выглядит как -1001234567890
GROUP_CHAT_ID=-1001234567890
